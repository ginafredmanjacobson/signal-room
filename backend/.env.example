# App
APP_NAME="SignalRoom"
DEBUG=True

# Database
DATABASE_URL="sqlite:///./signalroom.db"

# OpenAI
OPENAI_API_KEY="your-openai-key"
AI_MODE="live"  # or "mock" for testing without API

# Reddit API (get from https://www.reddit.com/prefs/apps)
REDDIT_CLIENT_ID="your-client-id"
REDDIT_CLIENT_SECRET="your-secret"
REDDIT_USER_AGENT="SignalRoom/1.0"

# RSS Feeds (comma-separated)
RSS_FEEDS="https://feeds.feedburner.com/example1,https://example2.com/rss"